# --- Build outputs / images (never publish in source; ISO ships as a Release asset) ---
*.iso
*.iso.*
*.img
*.qcow2
*.raw
*.vdi
*.vmdk

# --- archiso / build work + cache dirs ---
work/
iso-cache/
out/
build/
*.pkg.tar.*

# --- Python caches ---
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.venv/
venv/

# --- Secrets / personal data (HARD: must never enter history; see C2 scrub gate) ---
.env
.env.*
*.env
.hermes/
**/.hermes/
*.pem
*.key
id_ed25519*
id_rsa*
*_ed25519
*_rsa
*.exe
claude.exe
auth.json
credentials*.json
*.token

# --- OS / editor noise ---
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/

# --- Logs / scratch ---
*.log
logs/
tmp/
.cache/

# Build-time version stamps — generated, never committed (see build.sh)
airootfs/usr/local/share/ai-os/INSTALLED_REV
airootfs/usr/local/share/ai-os/INSTALLED_VERSION
# NOTE: MANIFEST.sha256 IS committed on purpose — the updater pulls it from the
# repo to detect locally-modified files and remove files dropped in a release.
# Keep it fresh with tools/gen-manifest.sh (make-release enforces this).
