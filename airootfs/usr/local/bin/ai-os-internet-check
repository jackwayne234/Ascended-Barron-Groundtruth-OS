#!/usr/bin/env bash
set -u
clear
echo "AI OS - 3 Internet Check"
echo "========================"
echo
ok=1
if ping -c 2 -W 3 1.1.1.1 >/dev/null 2>&1; then
  echo "PASS: Internet by IP works."
else
  echo "FAIL: Cannot reach 1.1.1.1 yet."
  ok=0
fi
if ping -c 2 -W 3 archlinux.org >/dev/null 2>&1; then
  echo "PASS: DNS/name lookup works."
else
  echo "FAIL: DNS/name lookup is not working yet."
  ok=0
fi

echo
if [ "$ok" = 1 ]; then
  echo "Internet is ready."
else
  echo "Internet is not fully ready. Click 1 WiFi Setup, then 2 Router Check again."
fi

echo
read -rp "Press Enter to close..." _
